{
  "name": "vstext",
  "version": "0.2.0",
  "description": "A cross-platform text editor for the browser and desktop with tabbed editing, Markdown preview, and syntax highlighting. Connects to cloud services like OneDrive, Google Drive, and Dropbox, allowing you to work on your files and keep your tabs, layout, and session in sync - so you pick up right where you left off on any device.",
  "author": "Victor Santos",
  "license": "Apache-2.0",
  "homepage": "https://text.vshub.app",
  "private": true,
  "type": "module",
  "main": "apps/desktop/main.cjs",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm dev:web",
    "dev:web": "vite --config apps/web/vite.config.ts",
    "dev:desktop": "concurrently -k \"pnpm dev:web\" \"wait-on tcp:5173 && electron ./apps/desktop/main.cjs\"",
    "build": "pnpm build:web",
    "build:web": "tsc -p apps/web/tsconfig.json && vite build --config apps/web/vite.config.ts",
    "dist:win": "pnpm build:web && electron-builder --win portable --x64",
    "preview": "pnpm preview:web",
    "preview:web": "vite preview --config apps/web/vite.config.ts",
    "test": "pnpm test:web",
    "test:web": "vitest run --config apps/web/vite.config.ts",
    "test:watch": "pnpm test:web:watch",
    "test:web:watch": "vitest --config apps/web/vite.config.ts"
  },
  "build": {
    "appId": "text.vshub.app",
    "productName": "vsText",
    "asar": true,
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "apps/desktop/**/*",
      "dist/apps/web/**/*",
      "packages/core/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.3.3",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.38.6",
    "@uiw/react-codemirror": "^4.25.2",
    "dexie": "^4.0.11",
    "lucide-react": "^1.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "vite-plugin-pwa": "^1.0.2",
    "workbox-window": "^7.4.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@types/node": "^24.0.13",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "electron": "^37.2.1",
    "electron-builder": "^26.8.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^26.1.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.3"
  }
}
